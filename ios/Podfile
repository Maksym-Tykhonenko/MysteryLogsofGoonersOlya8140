# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'MysteryLogsofGooners' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26.4's Apple Clang is stricter about C++20 consteval in fmt 11.0.2.
    # React Native 0.78 still vendors that fmt version, so patch it after pods install.
    fmt_base = File.join(installer.sandbox.pod_dir('fmt'), 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      patched_contents = contents.gsub(/^#\s*define FMT_USE_CONSTEVAL 1\s*$/, '#  define FMT_USE_CONSTEVAL 0')
      if patched_contents != contents
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched_contents)
      end
    end

    # Yoga ships with -Werror in RN 0.78; newer Xcode warnings should not fail archive builds.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'Yoga'

      target.source_build_phase.files.each do |source_file|
        flags = source_file.settings && source_file.settings['COMPILER_FLAGS']
        next unless flags

        source_file.settings['COMPILER_FLAGS'] = flags.split.reject { |flag| flag == '-Werror' }.join(' ')
      end
    end
  end
end
